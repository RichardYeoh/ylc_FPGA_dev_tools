// 将键绑定放在此文件中以覆盖默认值
[
   {
      "key": "ctrl+alt+c",
      "command": "toggleFindCaseSensitive",
      "when": "editorFocus"
   },
   {
      "key": "alt+c",
      "command": "-toggleFindCaseSensitive",
      "when": "editorFocus"
   },
   {
      "key": "alt+c",
      "command": "editor.action.toggleColumnSelection",
      "when": "editorTextFocus"
   }
]